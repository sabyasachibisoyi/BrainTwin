# DigitalTwin / BrainTwin Environment Variables
# Copy this file to .env and fill in your values

# ----- Phase 4.0.6 M.1 — bearer token (REQUIRED) ---------------------
# Shared secret. /capture, /recall, /stats, /failures require it.
# /, /health stay public.
#
# Generate a strong one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# In cloud, this is fetched from SSM Parameter Store at boot; this
# .env path is for local docker-compose only.
BACKEND_BEARER_TOKEN=replace-me-with-a-long-random-string

# Anthropic Claude API Key
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Telegram Bot Token
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Telegram allowlist
# Comma-separated Telegram user IDs that the bot will accept messages from.
# Send /start to your bot once after creating it — it will DM you your own
# user ID, which you can paste here.
ALLOWED_TELEGRAM_USER_IDS=

# Where the bot POSTs captures (same machine in Phase 1)
BACKEND_CAPTURE_URL=http://127.0.0.1:8000/capture

# Telegram bot state file (pause flag + last-seen timestamp)
TELEGRAM_STATE_PATH=./data/telegram_state.json

# Persistent capture-failure log (used by both Chrome and Telegram clients)
CAPTURE_FAILURES_PATH=./data/capture_failures.jsonl

# Server Settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Capture Settings
DWELL_TIME_THRESHOLD=30

# LLM Models
ENRICHMENT_MODEL=claude-haiku-4-5-20251001
AGENT_MODEL=claude-sonnet-4-6

# Database Paths
CHROMA_PATH=./data/chroma
SQLITE_PATH=./data/braintwin.db
IMAGES_PATH=./data/images
